# =============================================
# PORTFOLIO PLATFORM — BACKEND ENV VARIABLES
# =============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_platform
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# Cloudinary (for certificate/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP (for contact form → user's Gmail)
# Use an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_platform_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Admin setup (first admin account)
ADMIN_EMAIL=admin@yourplatform.com
ADMIN_PASSWORD=change_this_password
